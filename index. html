<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Anime Adda | Sliding Funnel</title>
  <style>
    body { font-family: Arial, sans-serif; margin:0; background:#0f172a; color:#fff; overflow-x:hidden; }
    .container { max-width:900px; margin:auto; padding:20px; }
    h1 { color:#38bdf8; text-align:center; }
    .card { background:#1e293b; padding:20px; border-radius:12px; margin:20px 0; }
    .btn { display:block; text-align:center; padding:14px; margin-top:10px; background:#22c55e; color:#000; font-weight:bold; border-radius:8px; text-decoration:none; }

    /* SLIDER */
    .slider {
      display:flex;
      overflow-x:auto;
      scroll-snap-type:x mandatory;
      gap:15px;
      padding:15px;
    }
    .slide {
      min-width:250px;
      background:#1e293b;
      padding:15px;
      border-radius:12px;
      scroll-snap-align:start;
    }
    .slide h3 { margin-top:0; }

    .topbar {
      background:#020617;
      padding:10px;
      text-align:center;
      position:sticky;
      top:0;
    }
  </style>
</head>
<body>

<div class="topbar">🔥 Swipe Products → Buy Fast</div>

<div class="container">

  <h1>🔥 Trending Anime Deals</h1>

  <!-- SLIDING PRODUCTS -->
  <div class="slider">

    <div class="slide" data-product="naruto">
      <h3>Naruto Figure</h3>
      <p>Top selling collectible</p>
      <a class="btn" href="https://www.amazon.in/dp/B0FZ9JG3FZ?tag=animeadda21" target="_blank" onclick="trackClick('naruto')"><a href="#">Buy Now</a>
    </div>

    <div class="slide" data-product="gojo">
      <h3>Gojo Poster</h3>
      <p>Trending wall art</p>
      <a class="btn" href="https://www.amazon.in/dp/B0FZ9JG3FZ?tag=animeadda21" target="_blank" onclick="trackClick('gojo')"><a href="https://www.amazon.in/dp/PRODUCT_ID?tag=animeadda21-21" target="_blank" class="buy-btn">
  Buy Now
</a>
    </div>

    <div class="slide" data-product="hoodie">
      <h3>Anime Hoodie</h3>
      <p>Stylish & comfortable</p>
      <a class="btn" href="https://www.amazon.in/dp/B0FZ9JG3FZ?tag=animeadda21" target="_blank" onclick="trackClick('hoodie')">Buy Now</a>
    </div>

  </div>

  <!-- MAIN CTA -->
  <div class="card">
    <h2>⚡ Limited Stock</h2>
    <p>These products are trending fast. Prices may increase soon.</p>
    <a class="btn" href="https://www.amazon.in/dp/B0FZ9JG3FZ?tag=animeadda21" target="_blank">🔥 Shop Now</a>
  </div>

</div>

<script>
function trackClick(product) {
  let clicks = JSON.parse(localStorage.getItem('clicks')) || {};
  clicks[product] = (clicks[product] || 0) + 1;
  localStorage.setItem('clicks', JSON.stringify(clicks));
}
</script>

</body>
</html>
